# Copia este archivo a ".env" en la raíz del proyecto y rellena los valores.
# Las variables coinciden con application.properties (${VARIABLE}).
# Si ya existen en el sistema operativo, tienen prioridad sobre .env
#
# Para Docker Compose usar un archivo aparte: copia .env.docker.example → .env.docker
# y ejecuta: docker compose --env-file .env.docker up --build

DATABASE_URL=jdbc:mysql://localhost:3306/pet_adoption
DATABASE_USERNAME=root
DATABASE_PASSWORD=

JWT_SECRET=cambiar-por-un-secreto-largo-y-aleatorio-en-produccion
JWT_EXPIRATION_MINUTES=60

CORS_ORIGIN_1=http://localhost:8080
CORS_ORIGIN_2=http://localhost:5173
