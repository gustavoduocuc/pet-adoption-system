# Plantilla para Docker Compose y contenedor de la app.
# Copia a ".env" en la raíz del proyecto o usa:
#   docker compose --env-file .env.docker.example up --build
#
# Host "mysql" es el nombre del servicio en docker-compose (solo válido dentro de la red de Compose).
# Si ejecutas la app en el host con ./mvnw y MySQL en Docker, usa DATABASE_URL con localhost.

MYSQL_ROOT_PASSWORD=cambiar_root_desarrollo

DATABASE_URL=jdbc:mysql://mysql:3306/pet_adoption
DATABASE_USERNAME=petuser
DATABASE_PASSWORD=cambiar_app_desarrollo

JWT_SECRET=cambiar-por-un-secreto-largo-y-aleatorio-en-produccion
JWT_EXPIRATION_MINUTES=60

CORS_ORIGIN_1=http://localhost:8080
CORS_ORIGIN_2=http://localhost:5173

# Opcional: si el puerto 3306 del host ya está ocupado por otro MySQL:
# MYSQL_HOST_PORT=3307
