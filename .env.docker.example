# Plantilla para Docker Compose (orientado a despliegue / paridad con prod).
# Desarrollo en tu JVM: usa ".env" con ./mvnw (puede ser root u otro usuario local).
#
# 1. cp .env.docker.example .env.docker
# 2. Definir contraseñas fuertes
# 3. docker compose --env-file .env.docker up --build
#    Con proxy HTTPS (Apache): genera certificados en docker/apache/certs/ y luego:
#    docker compose --env-file .env.docker --profile https up --build
#
# MYSQL_ROOT_PASSWORD: solo administración del servidor MySQL (healthcheck, tareas de DBA).
# MYSQL_APP_*: usuario con el que la app se conecta (no root; la imagen otorga permisos solo sobre MYSQL_DATABASE).
#
# COMPOSE_DATABASE_URL (opcional): JDBC que recibe el contenedor "app" dentro de la red Docker.
# Por defecto el compose usa jdbc:mysql://mysql:3306/pet_adoption (host = nombre del servicio, puerto interno 3306).
# No uses "localhost" ni el puerto publicado en el host (p. ej. 3307) aquí: dentro del contenedor no aplican.
# El archivo ".env" del host puede seguir definiendo DATABASE_URL=localhost para ./mvnw sin afectar a este stack.

MYSQL_ROOT_PASSWORD=cambiar_root_mysql

MYSQL_APP_USER=petapp
MYSQL_APP_PASSWORD=cambiar_password_app

# Opcional; si se omite, compose usa mysql:3306/pet_adoption:
# COMPOSE_DATABASE_URL=jdbc:mysql://mysql:3306/pet_adoption?allowPublicKeyRetrieval=true&useSSL=false

JWT_SECRET=cambiar-por-un-secreto-largo-y-aleatorio-en-produccion
JWT_EXPIRATION_MINUTES=60

CORS_ORIGIN_1=http://localhost:8080
CORS_ORIGIN_2=http://localhost:5173
# Si use usa el proxy HTTPS (perfil https) y el front llama a la API desde el navegador en https://localhost:
# CORS_ORIGIN_1=https://localhost

# Puerto HTTP del host que redirige a HTTPS (Apache, perfil https). Por defecto 80.
# HTTP_REDIRECT_HOST_PORT=80

# Puerto HTTPS del host para el contenedor Apache (perfil https). Por defecto 443.
# Si se cambia a otro (p. ej. 8443), la redirección desde el puerto 80 sigue mandando a https://host/ (puerto por defecto 443 del navegador): ajusta a mano o usa siempre la URL https con puerto explícito.
# HTTPS_HOST_PORT=443

# Certificados: generar en docker/apache/certs/ (ver docker/apache/certs/README.md) antes de --profile https.

# Opcional: IPs/CIDR para GET /actuator/health (coma). NOTA: En Docker puede hacer falta la red interna o el proxy.
# ACTUATOR_HEALTH_ALLOWED_IPS=127.0.0.1,10.0.0.0/8

# Opcional: si el puerto 3306 del host ya está ocupado por otro MySQL:
# MYSQL_HOST_PORT=3307
